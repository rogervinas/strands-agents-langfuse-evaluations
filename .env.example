# Model provider: ollama | bedrock | gemini (default: ollama)
MODEL_PROVIDER=ollama

# Ollama (default, local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Bedrock (requires AWS credentials)
# AWS_PROFILE=default
# AWS_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-sonnet-4-20250514-v1:0

# Gemini
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Langfuse (tracing + evaluations)
LANGFUSE_PUBLIC_KEY=publickey-local
LANGFUSE_SECRET_KEY=secretkey-local
LANGFUSE_BASE_URL=http://localhost:3000

# OpenTelemetry → Langfuse (traces from Strands Agents)
# AUTH = base64("LANGFUSE_PUBLIC_KEY:LANGFUSE_SECRET_KEY")
# echo -n "publickey-local:secretkey-local" | base64
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3000/api/public/otel
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic cHVibGlja2V5LWxvY2FsOnNlY3JldGtleS1sb2NhbA==

# Prompt management (set to true to fetch system prompt from Langfuse instead of hardcoded)
USE_LANGFUSE_PROMPT=false

# Annotation queue (run evals/langfuse/create_annotation_queue.py to get this ID)
ANNOTATION_QUEUE_ID=
